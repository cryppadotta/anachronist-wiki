{
  "name": "anachronist-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist --output-subdir pagefind",
    "build:site": "astro build",
    "build:search": "pagefind --site dist --output-subdir pagefind",
    "check": "astro check",
    "generate:page": "node --experimental-strip-types scripts/generate-page.ts",
    "generate:images": "node --experimental-strip-types scripts/generate-images.ts",
    "new:page": "node --experimental-strip-types scripts/new-page.ts",
    "validate:content": "node --experimental-strip-types scripts/validate-content.ts",
    "test:restricted-content": "node --experimental-strip-types scripts/restricted-content-regression.ts",
    "build:graph": "node --experimental-strip-types scripts/build-graph.ts",
    "repair:unlocks": "node --experimental-strip-types scripts/repair-unlocks.ts",
    "backfill:images": "node --experimental-strip-types scripts/generate-images.ts --all",
    "backfill:images:openai": "node --experimental-strip-types scripts/generate-images.ts --all --provider openai --model gpt-image-2",
    "preview": "astro preview",
    "pages:build": "npm run build"
  },
  "dependencies": {
    "astro": "6.2.1",
    "yaml": "2.8.4",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "^22.19.17",
    "pagefind": "^1.5.2",
    "typescript": "5.9.3"
  }
}
