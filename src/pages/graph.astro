---
import BaseLayout from "@layouts/BaseLayout.astro";
import { readFile } from "node:fs/promises";
import path from "node:path";
import { missingPath, pageRequestUrl, techPath } from "@lib/wiki";

interface GraphNode {
  slug: string;
  title: string;
  node_type: string;
  safety_class: string;
  status: string;
  summary: string;
  path: string;
  era_floor: string;
}

interface GraphEdge {
  from: string;
  to: string;
  kind: string;
  role: string;
  title?: string;
  source: string;
  declared_in: string;
}

interface MissingNode {
  slug: string;
  title: string;
  referenced_by: string[];
  reference_types: string[];
}

interface GraphFile {
  schema_version: number;
  nodes: GraphNode[];
  edges: GraphEdge[];
  missing_nodes: MissingNode[];
  diagnostics: Array<{ severity: string; message: string; slug?: string; file?: string }>;
}

const graphPath = path.join(process.cwd(), "generated", "tech-graph.json");
let graph: GraphFile = { schema_version: 1, nodes: [], edges: [], missing_nodes: [], diagnostics: [] };

try {
  const raw = await readFile(graphPath, "utf8");
  graph = JSON.parse(raw) as GraphFile;
} catch (error) {
  console.warn("graph.astro: failed to read tech-graph.json", error);
}

const nodesBySlug = new Map(graph.nodes.map((node) => [node.slug, node]));
const missingBySlug = new Map(graph.missing_nodes.map((node) => [node.slug, node]));

const nodesByType = new Map<string, GraphNode[]>();
for (const node of graph.nodes) {
  const list = nodesByType.get(node.node_type) ?? [];
  list.push(node);
  nodesByType.set(node.node_type, list);
}

const errorCount = graph.diagnostics.filter((d) => d.severity === "error").length;
const warningCount = graph.diagnostics.filter((d) => d.severity === "warning").length;

const NODE_TYPE_ORDER = ["material", "tool", "process", "artifact", "knowledge", "measurement", "institution", "test"];
const sortedTypes = NODE_TYPE_ORDER.filter((t) => nodesByType.has(t));
for (const t of nodesByType.keys()) if (!sortedTypes.includes(t)) sortedTypes.push(t);

const TREE_NODE_WIDTH = 250;
const TREE_NODE_HEIGHT = 112;
const TREE_COLUMN_GAP = 96;
const TREE_ROW_GAP = 28;
const TREE_PADDING = 96;
const TREE_COLUMN_WIDTH = TREE_NODE_WIDTH + TREE_COLUMN_GAP;
const TREE_ROW_HEIGHT = TREE_NODE_HEIGHT + TREE_ROW_GAP;
const TYPE_SORT = new Map(NODE_TYPE_ORDER.map((type, index) => [type, index]));
const SAFETY_SORT = new Map(["allowed", "caution", "restricted", "blocked", "missing"].map((type, index) => [type, index]));
const ERA_ORDER = [
  { key: "prehistoric", label: "Stone Age", eras: ["prehistoric"] },
  { key: "neolithic_to_ancient", label: "Neolithic / Bronze", eras: ["neolithic_to_ancient"] },
  { key: "prehistoric_to_ancient", label: "Ancient foundations", eras: ["prehistoric_to_ancient"] },
  { key: "ancient", label: "Classical", eras: ["ancient"] },
  { key: "ancient_to_medieval", label: "Medieval", eras: ["ancient_to_medieval"] },
  { key: "early_modern_to_industrial", label: "Industrial", eras: ["early_modern_to_industrial"] },
  { key: "unknown", label: "Missing / unknown", eras: ["unknown"] }
] as const;
const ERA_INDEX: Map<string, number> = new Map(ERA_ORDER.flatMap((era, index) => era.eras.map((key) => [key, index] as const)));
const ERA_LABELS: Map<string, string> = new Map(ERA_ORDER.flatMap((era) => era.eras.map((key) => [key, era.label] as const)));
const EDGE_STYLE_LEGEND = [
  { className: "edge-style-hard", label: "hard / material" },
  { className: "edge-style-context", label: "knowledge / test" },
  { className: "edge-style-soft", label: "soft / optional" }
];

type TreeNode = {
  slug: string;
  title: string;
  node_type: string;
  safety_class: string;
  status: string;
  summary: string;
  path: string;
  era_floor: string;
  isMissing: boolean;
  layer: number;
  eraIndex: number;
  eraLabel: string;
  column: number;
  x: number;
  y: number;
};

const treeNodesBySlug = new Map<string, TreeNode>();

for (const node of graph.nodes) {
  treeNodesBySlug.set(node.slug, {
    ...node,
    isMissing: false,
    layer: 0,
    eraIndex: ERA_INDEX.get(node.era_floor) ?? ERA_INDEX.get("unknown") ?? 0,
    eraLabel: ERA_LABELS.get(node.era_floor) ?? "Missing / unknown",
    column: 0,
    x: 0,
    y: 0
  });
}

for (const node of graph.missing_nodes) {
  treeNodesBySlug.set(node.slug, {
    slug: node.slug,
    title: node.title,
    node_type: "missing",
    safety_class: "missing",
    status: "missing",
    summary: `Referenced by ${node.referenced_by.join(", ")}`,
    path: missingPath(node.slug),
    era_floor: "unknown",
    isMissing: true,
    layer: 0,
    eraIndex: ERA_INDEX.get("unknown") ?? 0,
    eraLabel: ERA_LABELS.get("unknown") ?? "Missing / unknown",
    column: 0,
    x: 0,
    y: 0
  });
}

const treeEdges = graph.edges.filter((edge) => treeNodesBySlug.has(edge.from) && treeNodesBySlug.has(edge.to));
const incomingTreeEdges = new Map<string, GraphEdge[]>();
for (const edge of treeEdges) {
  const incoming = incomingTreeEdges.get(edge.to) ?? [];
  incoming.push(edge);
  incomingTreeEdges.set(edge.to, incoming);
}

const layerMemo = new Map<string, number>();
const activeLayerStack = new Set<string>();
function layerFor(slug: string): number {
  const cached = layerMemo.get(slug);
  if (cached !== undefined) return cached;
  if (activeLayerStack.has(slug)) return 0;

  activeLayerStack.add(slug);
  let layer = 0;
  for (const edge of incomingTreeEdges.get(slug) ?? []) {
    if (edge.from !== slug && treeNodesBySlug.has(edge.from)) {
      layer = Math.max(layer, layerFor(edge.from) + 1);
    }
  }
  activeLayerStack.delete(slug);
  layerMemo.set(slug, layer);
  return layer;
}

for (const node of treeNodesBySlug.values()) {
  node.layer = layerFor(node.slug);
}

const eraGroups = new Map<number, TreeNode[]>();
for (const node of treeNodesBySlug.values()) {
  const era = eraGroups.get(node.eraIndex) ?? [];
  era.push(node);
  eraGroups.set(node.eraIndex, era);
}

const treeColumns = new Map<number, TreeNode[]>();
const eraBands: Array<{ label: string; x: number; width: number; count: number }> = [];
let nextColumn = 0;

for (const [eraIndex, era] of ERA_ORDER.entries()) {
  const nodesInEra = eraGroups.get(eraIndex) ?? [];
  if (nodesInEra.length === 0) continue;

  const layerRanks = [...new Set(nodesInEra.map((node) => node.layer))].sort((a, b) => a - b);
  const layerRankIndex = new Map(layerRanks.map((layer, index) => [layer, index]));
  const eraStartColumn = nextColumn;

  for (const node of nodesInEra) {
    node.column = eraStartColumn + (layerRankIndex.get(node.layer) ?? 0);
    const column = treeColumns.get(node.column) ?? [];
    column.push(node);
    treeColumns.set(node.column, column);
  }

  eraBands.push({
    label: era.label,
    x: TREE_PADDING + eraStartColumn * TREE_COLUMN_WIDTH,
    width: Math.max(TREE_NODE_WIDTH, layerRanks.length * TREE_COLUMN_WIDTH - TREE_COLUMN_GAP),
    count: nodesInEra.length
  });

  nextColumn += Math.max(1, layerRanks.length) + 1;
}

const sortedColumns = [...treeColumns.keys()].sort((a, b) => a - b);
for (const columnIndex of sortedColumns) {
  const column = treeColumns.get(columnIndex) ?? [];
  column.sort((a, b) => {
    const eraDiff = a.eraIndex - b.eraIndex;
    if (eraDiff !== 0) return eraDiff;
    const layerDiff = a.layer - b.layer;
    if (layerDiff !== 0) return layerDiff;
    const typeDiff = (TYPE_SORT.get(a.node_type) ?? 99) - (TYPE_SORT.get(b.node_type) ?? 99);
    if (typeDiff !== 0) return typeDiff;
    const safetyDiff = (SAFETY_SORT.get(a.safety_class) ?? 99) - (SAFETY_SORT.get(b.safety_class) ?? 99);
    if (safetyDiff !== 0) return safetyDiff;
    return a.title.localeCompare(b.title);
  });

  column.forEach((node, row) => {
    node.x = TREE_PADDING + columnIndex * TREE_COLUMN_WIDTH;
    node.y = TREE_PADDING + row * TREE_ROW_HEIGHT;
  });
}

const maxColumn = Math.max(0, ...sortedColumns);
const maxRows = Math.max(1, ...[...treeColumns.values()].map((column) => column.length));
const treeWidth = TREE_PADDING * 2 + (maxColumn + 1) * TREE_COLUMN_WIDTH;
const treeHeight = TREE_PADDING * 2 + maxRows * TREE_ROW_HEIGHT;
const treeNodes = [...treeNodesBySlug.values()].sort((a, b) => a.column - b.column || a.y - b.y || a.title.localeCompare(b.title));

function edgePath(edge: GraphEdge) {
  const fromNode = treeNodesBySlug.get(edge.from);
  const toNode = treeNodesBySlug.get(edge.to);
  if (!fromNode || !toNode) return "";

  const startX = fromNode.x + TREE_NODE_WIDTH;
  const startY = fromNode.y + TREE_NODE_HEIGHT / 2;
  const endX = toNode.x;
  const endY = toNode.y + TREE_NODE_HEIGHT / 2;
  const controlOffset = Math.max(72, Math.abs(endX - startX) * 0.42);

  return `M ${startX} ${startY} C ${startX + controlOffset} ${startY}, ${endX - controlOffset} ${endY}, ${endX} ${endY}`;
}
---

<BaseLayout title="Graph" description="Browse the Anachronist Wiki technology tree by node type, safety class, and prerequisite edges.">
  <section class="graph-page">
    <header class="graph-hero">
      <p class="eyebrow">Technology graph</p>
      <h1>Tree of useful things</h1>
      <p>Built from <code>generated/tech-graph.json</code>. Pages are nodes; explicit frontmatter relations are edges. Red rings are declared-missing prerequisites that need a page request.</p>
      <ul class="graph-stats">
        <li><strong>{graph.nodes.length}</strong> pages</li>
        <li><strong>{graph.edges.length}</strong> edges</li>
        <li><strong>{graph.missing_nodes.length}</strong> missing prereqs</li>
        <li class={errorCount > 0 ? "graph-stat-bad" : "graph-stat-ok"}><strong>{errorCount}</strong> errors</li>
        <li class={warningCount > 0 ? "graph-stat-warn" : "graph-stat-ok"}><strong>{warningCount}</strong> warnings</li>
      </ul>
    </header>

    {graph.nodes.length === 0 ? (
      <div class="callout">
        <p>No graph data yet. Run <code>npm run build:graph</code> after adding content under <code>content/tech/</code>.</p>
      </div>
    ) : (
      <>
        <section class="tech-tree-panel" aria-labelledby="tech-tree-heading">
          <div class="tech-tree-toolbar">
            <div>
              <p class="eyebrow">Pannable map</p>
              <h2 id="tech-tree-heading">Civilization-style tech tree</h2>
            </div>
            <div class="tech-tree-controls" aria-label="Tree controls">
              <label class="tree-search">
                <span>Find</span>
                <input type="search" placeholder="rope, kiln, writing..." data-tree-search />
              </label>
              <button type="button" class="tree-icon-button" data-tree-zoom="out" aria-label="Zoom out" title="Zoom out">−</button>
              <button type="button" class="tree-icon-button" data-tree-zoom="in" aria-label="Zoom in" title="Zoom in">+</button>
              <button type="button" class="tree-fit-button" data-tree-fit aria-label="Fit tree to viewport" title="Fit tree to viewport">Fit</button>
            </div>
          </div>
          <details class="tech-tree-legend" data-tree-legend open>
            <summary>Legend</summary>
            <div class="tech-tree-legend-grid" aria-label="Graph legend">
              <div class="tech-tree-legend-group" aria-label="Node types">
                {NODE_TYPE_ORDER.map((type) => <span class={`tree-type-key tree-type-${type}`}>{type}</span>)}
                <span class="tree-type-key tree-type-missing">missing</span>
              </div>
              <div class="tech-tree-legend-group" aria-label="Edge styles">
                {EDGE_STYLE_LEGEND.map((edge) => <span class={`tree-edge-key ${edge.className}`}>{edge.label}</span>)}
              </div>
            </div>
          </details>
          <div class="tech-tree-viewport" data-tree-viewport tabindex="0" aria-label="Pannable technology tree. Drag or use arrow keys to pan, slash to search, plus and minus to zoom, and zero to fit.">
            <div class="tech-tree-era-ruler" style={`width: ${treeWidth}px;`}>
              {eraBands.map((era) => (
                <span class="tree-era-label" style={`left: ${era.x}px; width: ${era.width}px;`}>
                  <strong>{era.label}</strong>
                  <em>{era.count} nodes</em>
                </span>
              ))}
            </div>
            <div class="tech-tree-canvas" data-tree-canvas style={`width: ${treeWidth}px; height: ${treeHeight}px;`}>
              <div class="tech-tree-era-bands" aria-hidden="true">
                {eraBands.map((era) => (
                  <span class="tree-era-band" style={`left: ${era.x}px; width: ${era.width}px;`}></span>
                ))}
              </div>
              <svg class="tech-tree-edges" width={treeWidth} height={treeHeight} viewBox={`0 0 ${treeWidth} ${treeHeight}`} aria-hidden="true">
                <defs>
                  <marker id="tree-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                    <path d="M 0 0 L 10 5 L 0 10 z"></path>
                  </marker>
                </defs>
                {treeEdges.map((edge) => (
                  <path
                    class={`tree-edge tree-edge-${edge.kind}`}
                    d={edgePath(edge)}
                    data-tree-edge
                    data-edge-from={edge.from}
                    data-edge-to={edge.to}
                  ></path>
                ))}
              </svg>
              {treeNodes.map((node) => (
                <a
                  class={`tree-node tree-node-${node.node_type} safety-${node.safety_class}${node.isMissing ? " tree-node-missing" : ""}`}
                  href={node.path}
                  style={`left: ${node.x}px; top: ${node.y}px; width: ${TREE_NODE_WIDTH}px; min-height: ${TREE_NODE_HEIGHT}px;`}
                  data-tree-node
                  data-tree-title={node.title.toLowerCase()}
                  data-tree-slug={node.slug}
                  data-tree-era={node.eraLabel}
                >
                  <span class="tree-node-type">{node.node_type}</span>
                  <strong>{node.title}</strong>
                  <span class="tree-node-meta">{node.safety_class}</span>
                  <span class="tree-node-summary">{node.summary}</span>
                </a>
              ))}
            </div>
          </div>
        </section>

        <section class="graph-section" aria-label="Graph by node type">
          <h2>By node type</h2>
          <div class="graph-clusters">
            {sortedTypes.map((nodeType) => (
              <article class={`graph-cluster cluster-${nodeType}`}>
                <h3>{nodeType}<span>{(nodesByType.get(nodeType) ?? []).length}</span></h3>
                <ul>
                  {(nodesByType.get(nodeType) ?? []).map((node) => (
                    <li class={`graph-node-row safety-${node.safety_class}`}>
                      <a href={node.path}>{node.title}</a>
                      <span class="node-meta">{node.era_floor} · {node.status}</span>
                      <p class="muted small">{node.summary}</p>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section class="graph-section" aria-label="Graph edges">
          <h2>Edges ({graph.edges.length})</h2>
          <div class="table-wrap">
            <table class="graph-table">
              <thead>
                <tr><th>From</th><th>Kind</th><th>To</th><th>Role</th></tr>
              </thead>
              <tbody>
                {graph.edges.map((edge) => {
                  const fromNode = nodesBySlug.get(edge.from);
                  const toNode = nodesBySlug.get(edge.to);
                  const fromHref = fromNode ? techPath(edge.from) : missingBySlug.has(edge.from) ? missingPath(edge.from) : `/missing/${edge.from}/`;
                  const toHref = toNode ? techPath(edge.to) : missingBySlug.has(edge.to) ? missingPath(edge.to) : `/missing/${edge.to}/`;
                  const fromTitle = fromNode?.title ?? missingBySlug.get(edge.from)?.title ?? edge.from;
                  const toTitle = toNode?.title ?? missingBySlug.get(edge.to)?.title ?? edge.title ?? edge.to;
                  return (
                    <tr class={`edge-row edge-${edge.kind}`}>
                      <td class={fromNode ? "" : "missing-link"}><a href={fromHref}>{fromTitle}</a></td>
                      <td><span class={`edge-chip edge-chip-${edge.kind}`}>{edge.kind}</span></td>
                      <td class={toNode ? "" : "missing-link"}><a href={toHref}>{toTitle}</a></td>
                      <td>{edge.role}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>

        <section class="graph-section" aria-label="Missing prerequisites">
          <h2>Missing prerequisites ({graph.missing_nodes.length})</h2>
          <p>These slugs are referenced by existing pages but have no source file yet. Each one renders at <code>/missing/&lt;slug&gt;/</code> and links to a GitHub page request.</p>
          <ul class="missing-grid">
            {graph.missing_nodes.map((node) => (
              <li class="missing-pill">
                <a class="missing-pill-link" href={missingPath(node.slug)}>{node.title}</a>
                <span class="muted small">referenced by {node.referenced_by.join(", ")}</span>
                <a class="inline-action" href={pageRequestUrl(node.title)}>Request page</a>
              </li>
            ))}
          </ul>
        </section>

        {graph.diagnostics.length > 0 && (
          <details class="graph-diagnostics">
            <summary>Validator diagnostics ({graph.diagnostics.length})</summary>
            <ul>
              {graph.diagnostics.map((d) => (
                <li class={`diag diag-${d.severity}`}>
                  <strong>{d.severity}</strong>
                  {d.slug && <code>{d.slug}</code>}
                  <span>{d.message}</span>
                </li>
              ))}
            </ul>
          </details>
        )}
      </>
    )}
  </section>
</BaseLayout>

<script>
  const viewport = document.querySelector("[data-tree-viewport]");
  const canvas = document.querySelector("[data-tree-canvas]");
  const searchInput = document.querySelector("[data-tree-search]");
  const fitButton = document.querySelector("[data-tree-fit]");
  const zoomButtons = document.querySelectorAll("[data-tree-zoom]");
  const treeNodes = [...document.querySelectorAll("[data-tree-node]")];
  const treeEdges = [...document.querySelectorAll("[data-tree-edge]")];
  const legend = document.querySelector("[data-tree-legend]");

  if (viewport instanceof HTMLElement && canvas instanceof HTMLElement) {
    let scale = 1;
    let isPanning = false;
    let hasDragged = false;
    let startX = 0;
    let startY = 0;
    let startScrollLeft = 0;
    let startScrollTop = 0;

    const applyScale = (nextScale: number) => {
      const previousScale = scale;
      scale = Math.min(1.35, Math.max(0.25, nextScale));
      const scrollRatioX = (viewport.scrollLeft + viewport.clientWidth / 2) / previousScale;
      const scrollRatioY = (viewport.scrollTop + viewport.clientHeight / 2) / previousScale;
      canvas.style.transform = `scale(${scale})`;
      viewport.scrollLeft = scrollRatioX * scale - viewport.clientWidth / 2;
      viewport.scrollTop = scrollRatioY * scale - viewport.clientHeight / 2;
    };

    const fitTree = () => {
      const fitScale = Math.min(1, Math.max(0.25, Math.min(viewport.clientWidth / canvas.offsetWidth, viewport.clientHeight / canvas.offsetHeight) * 0.92));
      applyScale(fitScale);
      viewport.scrollLeft = Math.max(0, (canvas.offsetWidth * scale - viewport.clientWidth) / 2);
      viewport.scrollTop = 0;
    };

    const startTree = () => {
      viewport.scrollLeft = 0;
      viewport.scrollTop = 0;
    };

    if (legend instanceof HTMLDetailsElement && window.matchMedia("(max-width: 640px)").matches) {
      legend.removeAttribute("open");
    }

    requestAnimationFrame(startTree);

    viewport.addEventListener("pointerdown", (event) => {
      if (!(event.target instanceof Element) || event.target.closest("a, button, input")) return;
      isPanning = true;
      hasDragged = false;
      startX = event.clientX;
      startY = event.clientY;
      startScrollLeft = viewport.scrollLeft;
      startScrollTop = viewport.scrollTop;
      viewport.setPointerCapture(event.pointerId);
      viewport.classList.add("is-panning");
    });

    viewport.addEventListener("pointermove", (event) => {
      if (!isPanning) return;
      const dx = event.clientX - startX;
      const dy = event.clientY - startY;
      if (Math.abs(dx) + Math.abs(dy) > 6) hasDragged = true;
      viewport.scrollLeft = startScrollLeft - dx;
      viewport.scrollTop = startScrollTop - dy;
    });

    viewport.addEventListener("pointerup", (event) => {
      isPanning = false;
      viewport.classList.remove("is-panning");
      if (viewport.hasPointerCapture(event.pointerId)) viewport.releasePointerCapture(event.pointerId);
      window.setTimeout(() => {
        hasDragged = false;
      }, 0);
    });

    viewport.addEventListener(
      "click",
      (event) => {
        if (hasDragged) {
          event.preventDefault();
          event.stopPropagation();
        }
      },
      true
    );

    zoomButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const direction = button.getAttribute("data-tree-zoom");
        applyScale(scale + (direction === "in" ? 0.12 : -0.12));
      });
    });

    fitButton?.addEventListener("click", () => {
      requestAnimationFrame(fitTree);
    });

    const clearEdgeFocus = () => {
      canvas.classList.remove("has-edge-focus");
      treeEdges.forEach((edge) => {
        edge.classList.remove("tree-edge-active", "tree-edge-dim");
      });
      treeNodes.forEach((node) => {
        node.classList.remove("tree-node-connected");
      });
    };

    const focusNodeEdges = (slug: string) => {
      const connectedSlugs = new Set([slug]);
      canvas.classList.add("has-edge-focus");
      treeEdges.forEach((edge) => {
        const from = edge.getAttribute("data-edge-from");
        const to = edge.getAttribute("data-edge-to");
        const isActive = from === slug || to === slug;
        edge.classList.toggle("tree-edge-active", isActive);
        edge.classList.toggle("tree-edge-dim", !isActive);
        if (isActive) {
          if (from) connectedSlugs.add(from);
          if (to) connectedSlugs.add(to);
        }
      });
      treeNodes.forEach((node) => {
        node.classList.toggle("tree-node-connected", connectedSlugs.has(node.getAttribute("data-tree-slug") ?? ""));
      });
    };

    treeNodes.forEach((node) => {
      node.addEventListener("mouseenter", () => {
        focusNodeEdges(node.getAttribute("data-tree-slug") ?? "");
      });
      node.addEventListener("focus", () => {
        focusNodeEdges(node.getAttribute("data-tree-slug") ?? "");
      });
      node.addEventListener("mouseleave", clearEdgeFocus);
      node.addEventListener("blur", clearEdgeFocus);
    });

    viewport.addEventListener("keydown", (event) => {
      const panAmount = event.shiftKey ? 180 : 80;
      if (event.key === "ArrowLeft") {
        viewport.scrollLeft -= panAmount;
        event.preventDefault();
      } else if (event.key === "ArrowRight") {
        viewport.scrollLeft += panAmount;
        event.preventDefault();
      } else if (event.key === "ArrowUp") {
        viewport.scrollTop -= panAmount;
        event.preventDefault();
      } else if (event.key === "ArrowDown") {
        viewport.scrollTop += panAmount;
        event.preventDefault();
      } else if (event.key === "+" || event.key === "=") {
        applyScale(scale + 0.12);
        event.preventDefault();
      } else if (event.key === "-" || event.key === "_") {
        applyScale(scale - 0.12);
        event.preventDefault();
      } else if (event.key === "0") {
        fitTree();
        event.preventDefault();
      } else if (event.key === "/") {
        if (searchInput instanceof HTMLInputElement) searchInput.focus();
        event.preventDefault();
      }
    });

    searchInput?.addEventListener("input", () => {
      if (!(searchInput instanceof HTMLInputElement)) return;
      const query = searchInput.value.trim().toLowerCase();
      let firstMatch: Element | null = null;
      for (const node of treeNodes) {
        const match = query.length > 0 && `${node.getAttribute("data-tree-title")} ${node.getAttribute("data-tree-slug")}`.includes(query);
        node.classList.toggle("tree-node-match", match);
        node.classList.toggle("tree-node-dim", query.length > 0 && !match);
        if (match && firstMatch === null) firstMatch = node;
      }

      if (firstMatch instanceof HTMLElement) {
        viewport.scrollTo({
          left: firstMatch.offsetLeft * scale - viewport.clientWidth / 2 + firstMatch.offsetWidth / 2,
          top: firstMatch.offsetTop * scale - viewport.clientHeight / 2 + firstMatch.offsetHeight / 2,
          behavior: "smooth"
        });
      }
    });
  }
</script>
