---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title,
  description = "A static field manual for rebuilding useful technologies from earlier prerequisites.",
  image,
  type = "website"
} = Astro.props;

const pageTitle = `${title} | Anachronist Wiki`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const absoluteImageUrl = image ? new URL(image, Astro.site ?? Astro.url).toString() : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    {absoluteImageUrl && <meta property="og:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:alt" content={title} />}
    <meta name="twitter:card" content={absoluteImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {absoluteImageUrl && <meta name="twitter:image" content={absoluteImageUrl} />}
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Anachronist Wiki home">
        <span class="brand-mark">AW</span>
        <span>Anachronist Wiki</span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href="/graph/">Graph</a>
        <a href="/search/">Search</a>
        <a href="/missing/">Missing</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Static GitHub-backed wiki. Page requests use GitHub Issues; edits use GitHub PRs.</p>
    </footer>
  </body>
</html>
